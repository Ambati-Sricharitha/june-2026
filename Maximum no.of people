class Solution:
    def maxPeopleDefeated(self, p):
        # code here
        low,high=0,int((3*p)**(1/3))+100
        while low<=high:
            mid=(low+high)//2
            s=mid*(mid+1)*(2*mid+1)//6
            if s<=p:
                low=mid+1
            else:
                high=mid-1
        return high
